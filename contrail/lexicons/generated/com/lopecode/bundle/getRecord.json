{
  "lexicon": 1,
  "id": "com.lopecode.bundle.getRecord",
  "defs": {
    "main": {
      "type": "query",
      "description": "Get a single com.lopecode.bundle record by AT URI",
      "parameters": {
        "type": "params",
        "required": [
          "uri"
        ],
        "properties": {
          "uri": {
            "type": "string",
            "format": "at-uri",
            "description": "AT URI of the record"
          },
          "profiles": {
            "type": "boolean",
            "description": "Include profile + identity info keyed by DID"
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": [
            "uri",
            "value",
            "did",
            "collection",
            "rkey",
            "time_us"
          ],
          "properties": {
            "uri": {
              "type": "string",
              "format": "at-uri"
            },
            "cid": {
              "type": "string",
              "format": "cid"
            },
            "value": {
              "type": "ref",
              "ref": "com.lopecode.bundle#main"
            },
            "did": {
              "type": "string",
              "format": "did"
            },
            "collection": {
              "type": "string",
              "format": "nsid"
            },
            "rkey": {
              "type": "string"
            },
            "time_us": {
              "type": "integer"
            },
            "profiles": {
              "type": "array",
              "items": {
                "type": "ref",
                "ref": "#profileEntry"
              }
            }
          }
        }
      }
    },
    "profileEntry": {
      "type": "object",
      "required": [
        "did"
      ],
      "properties": {
        "did": {
          "type": "string",
          "format": "did"
        },
        "handle": {
          "type": "string"
        },
        "uri": {
          "type": "string",
          "format": "at-uri"
        },
        "cid": {
          "type": "string",
          "format": "cid"
        },
        "value": {
          "type": "unknown"
        },
        "collection": {
          "type": "string",
          "format": "nsid"
        },
        "rkey": {
          "type": "string"
        }
      }
    }
  }
}
